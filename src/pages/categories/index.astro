---
import CustomPage from '../../components/CustomPage.astro';
import siteData from '../../generated/site-data.json';
---

<CustomPage title="Posts by Category" description="Browse posts grouped by category.">
  <div class="taxonomy-grid">
    {siteData.categories.map((category) => (
      <article class="taxonomy-card" id={category.slug}>
        <div class="taxonomy-header">
          <h2>{category.name}</h2>
          <span>{category.count}</span>
        </div>
        <ul>
          {category.items.slice(0, 8).map((item) => (
            <li><a href={item.url}>{item.title}</a></li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</CustomPage>
