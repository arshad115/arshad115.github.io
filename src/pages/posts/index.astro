---
import CustomPage from '../../components/CustomPage.astro';
import PostMetaRow from '../../components/PostMetaRow.astro';
import siteData from '../../generated/site-data.json';

const posts = [...siteData.posts].sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());
---

<CustomPage title="All Posts" description="Browse every blog post in chronological order.">
  <div class="stack-list">
    {posts.map((post) => (
      <article class="stack-item">
        <h2><a href={post.url}>{post.title}</a></h2>
        <PostMetaRow
          pubDate={post.pubDate}
          readingTime={post.readingTime}
          category={post.category}
          categorySlug={post.categorySlug}
        />
        {post.excerpt && <p>{post.excerpt}</p>}
      </article>
    ))}
  </div>
</CustomPage>

<style is:global>
  .stack-list {
    gap: 0.9rem;
  }

  .stack-list .stack-item {
    display: grid;
    gap: 0.45rem;
  }

  .stack-list .stack-item p {
    margin: 0;
  }

  .stack-list .stack-item h2 {
    margin: 0;
  }

  .stack-list .stack-item .meta-row {
    margin-top: 0.28rem;
    margin-bottom: 0.22rem;
  }
</style>
