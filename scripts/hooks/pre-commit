#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
cd "$REPO_ROOT"

if ! command -v node > /dev/null 2>&1; then
  echo "⚠️  node is not installed. Skipping generated content refresh."
  exit 0
fi

CHANGED_FILES="$(git diff --cached --name-only)"

if ! grep -Eq '^(src/|scripts/|content/|today-i-learned/|package(-lock)?\.json|astro\.config\.mjs|public/)' <<< "$CHANGED_FILES"; then
  exit 0
fi

echo "🔄 Refreshing generated Astro content"
node scripts/generate-content.mjs
